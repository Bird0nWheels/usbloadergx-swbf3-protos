*.dol
*.elf
*.exe
*.bat
.vscode/
build/
usbloader_gx/
/HBC/meta.xml
/source/themes/filelist.h
/source/version.h
/usbloader_gx.zip

# allow batch scripts shipped under tools/
!tools/**/*.bat

# don't track anything generated by the proto-pipeline at runtime:
# - tools/         <- downloaded rvthtool + wit binaries (third-party)
# - work/          <- intermediate retail isos, half-built WBFSes
# - out/           <- staged final WBFS folders (per-user output)
tools/proto-pipeline/tools/
tools/proto-pipeline/work/
tools/proto-pipeline/out/

# also catch any zip leftovers
tools/proto-pipeline/*.zip
