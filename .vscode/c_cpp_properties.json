                "HW_RVL",
                "GEKKO",
                "__wii__",
                "DEVKITPRO"
            ],
            "compilerPath": "${env:DEVKITPRO}/devkitPPC/bin/powerpc-eabi-gcc",
            "cStandard": "gnu17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-arm"
        },
        {
            "name": "Mac",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:DEVKITPRO}/libogc/include/**"
            ],
            "defines": [
                "HW_RVL",
                "GEKKO",
                "__wii__",
                "DEVKITPRO"
            ],
            "compilerPath": "${env:DEVKITPRO}/devkitPPC/bin/powerpc-eabi-gcc",
            "cStandard": "gnu17",
            "cppStandard": "gnu++17",
