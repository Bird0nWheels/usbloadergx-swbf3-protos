{
    "env": {
        "DEVKITPROWIN": "C:/devkitPro"
    },
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**",
                "${DEVKITPROWIN}/libogc/include/**"
            ],
            "defines": [
                "HW_RVL",
                "GEKKO",
                "__wii__",
                "DEVKITPRO"
            ],
            "compilerPath": "${DEVKITPROWIN}/devkitPPC/bin/powerpc-eabi-gcc.exe",
            "cStandard": "gnu17",
            "cppStandard": "gnu++17",
            "intelliSenseMode": "linux-gcc-arm"
        },
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:DEVKITPRO}/libogc/include/**"
            ],
